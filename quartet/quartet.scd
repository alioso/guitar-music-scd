// ─────────────────────────────────────────────────────────────────────────────
// PLAYBACK ENGINE
// ─────────────────────────────────────────────────────────────────────────────

// Convert score array into a Dictionary keyed by bar number
~buildBarIndex = { |score|
    var index = Dictionary.new;
    score.do { |ev|
        var bar  = ev[0];
        var list = index.at(bar) ?? { var l = List.new; index.put(bar, l); l };
        list.add(ev);
    };
    index
};

~g2idx = ~buildBarIndex.(~g2score);
~g3idx = ~buildBarIndex.(~g3score);
~g4idx = ~buildBarIndex.(~g4score);

// Current bar cursor (shared)
~currentBar = 1;
~running     = false;
~reverbBus   = Bus.audio(s, 2);

// Map bar number → tempo (interpolated)
~tempoAtBar = { |bar|
    var map  = ~q.tempoMap;
    var bpm  = map[0][1];
    (map.size - 1).do { |i|
        var lo = map[i]; var hi = map[i+1];
        if (bar >= lo[0] and: { bar < hi[0] }) {
            var frac = (bar - lo[0]) / (hi[0] - lo[0]);
            bpm = lo[1] + (frac * (hi[1] - lo[0]));
        };
        if (bar >= hi[0]) { bpm = hi[1] };
    };
    bpm
};

// Decay estimate by MIDI note (higher = shorter)
~decayForMidi = { |midi|
    var norm = (midi - 40).clip(0, 48) / 48.0;  // 0 at E2, 1 at E6
    3.5 - (norm * 2.5)                           // 3.5s bass → 1.0s high
};

// Fire all events in a given bar for a given partner
~fireBar = { |barIdx, pan, jitter, ampMul|
    var events = barIdx.at(~currentBar);
    if (events.notNil) {
        events.do { |ev|
            var bar=ev[0], beat=ev[1], midi=ev[2], dur=ev[3], amp=ev[4];
            var bpm     = ~tempoAtBar.(bar);
            var secPerBeat = 60.0 / bpm;
            var beatDelay  = (beat - 1) * secPerBeat;
            var timingOff  = jitter.rand2;
            var actualAmp  = (amp * ampMul * (1.0 + ~q.ampJitter.rand2)).clip(0, 1);
            var freq       = midi.midicps;
            var decay      = ~decayForMidi.(midi);
            s.makeBundle(beatDelay + timingOff, {
                Synth(\gtr, [
                    \out,    ~reverbBus.index,
                    \freq,   freq,
                    \amp,    actualAmp,
                    \decay,  decay,
                    \bright, 0.45 + 0.08.rand2,
                    \pan,    pan + 0.08.rand2,
                ]);
            });
        };
    };
};

// Advance cursor — called by footpedal or auto-timeout
~advanceCursor = {
    ~currentBar = ~currentBar + 1;
    if (~currentBar > 110) { ~running = false; "Piece ended.".postln; };
};

// Main playback loop — one iteration per bar
~playRoutine = Routine({
    var bpm, secPerBar;
    ~running = true;
    ~currentBar = 1;

    // Boot reverb
    Synth(\qtrReverb, [\in, ~reverbBus.index, \out, ~q.partnerOut]);

    while { ~running } {
        bpm       = ~tempoAtBar.(~currentBar);
        secPerBar = (60.0 / bpm) * 4;

        // Update TempoClock for click
        TempoClock.default.tempo = bpm / 60.0;

        // Fire partner bars concurrently
        fork {
            ~fireBar.(~g2idx, ~q.pans[0], ~q.timingJitter, 1.0);
            ~fireBar.(~g3idx, ~q.pans[1], ~q.timingJitter, 1.0);
            ~fireBar.(~g4idx, ~q.pans[2], ~q.timingJitter, 1.1);
        };

        secPerBar.wait;
        ~advanceCursor.();
    };
}).play(SystemClock);

// ── Click track ───────────────────────────────────────────────────────────────
~clickRoutine = Routine({
    while { ~running.not } { 0.1.wait };  // wait for start
    while { ~running } {
        var bpm         = ~tempoAtBar.(~currentBar);
        var secPerBeat  = 60.0 / bpm;
        // Downbeat: higher pitch
        Synth(\click, [\out, ~q.clickOut, \freq, 1320, \amp, 0.7]);
        secPerBeat.wait;
        3.do {
            Synth(\click, [\out, ~q.clickOut, \freq, 880, \amp, 0.4]);
            secPerBeat.wait;
        };
    };
}).play(SystemClock);

// ── MIDI footpedal — CC64 sustain = advance cursor ───────────────────────────
MIDIClient.init;
MIDIIn.connectAll;
~pedalResponder = MIDIFunc.cc({ |val, num, chan|
    if (num == ~q.pedalCC and: { val > 63 }) {
        "Cursor advance: bar %".format(~currentBar + 1).postln;
        ~advanceCursor.();
    };
}, chan: ~q.midiChan);

"Quartet started. Use sustain pedal (CC64) to advance phrases.".postln;
"Current bar: %".format(~currentBar).postln;
)


// ─────────────────────────────────────────────────────────────────────────────
// BLOCK 3 — STOP
// ─────────────────────────────────────────────────────────────────────────────
(
~running = false;
~playRoutine.stop;
~clickRoutine.stop;
~pedalResponder.free;
~reverbBus.free;
s.freeAll;
"Quartet stopped.".postln;
)
