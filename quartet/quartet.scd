/*
Quartet No. 1
Pre-composed 4-guitar quartet — cursor-based advancement
SuperCollider 3.14.1

SETUP
  Input:  guitar → Scarlett input 0 (mono)
  Output: stereo 0+1 (speakers)   click → output 2+3 (headphones)

SECTIONS
  A  bars  1–16   ♩=110   introduction
  B  bars 17–32   ♩=110   development
  C  bars 33–48   ♩=92    contrast (sparse, high register)
  D  bars 49–64   ♩=110   recapitulation
  E  bars 65–88   ♩=110   build
  Coda bars 89–110 ♩=126→rit. final

OPERATION
  Block 1 — config + SynthDef boot (Cmd+Return)
  Block 2 — start piece (Cmd+Return after guitar 1 is ready)
  Block 3 — stop / panic

PARTNER GUITAR SOUND
  Karplus-Strong string model (Pluck UGen) + body resonance filters.
  Humanization: ±12ms timing jitter, ±10% amplitude variation per note.
  Decay scales with pitch (high notes decay faster).

CURSOR ADVANCEMENT
  Footpedal (MIDI CC 64, sustain pedal) advances the phrase cursor.
  Each press completes the current phrase and cues partners to the next section.
  Alternatively, SC auto-advances after a configurable timeout.
*/


// ─────────────────────────────────────────────────────────────────────────────
// BLOCK 1 — CONFIGURATION & SYNTHDEFS
// ─────────────────────────────────────────────────────────────────────────────
(
~q = (
    bpm:           110,
    clickOut:      2,         // output bus for click (headphones)
    partnerOut:    0,         // output bus for partner guitars
    midiChan:      0,         // MIDI channel for footpedal
    pedalCC:       64,        // CC number: sustain pedal = phrase advance
    autoAdvance:   true,      // auto-advance after timeout if no pedal press
    autoTimeout:   8.0,       // seconds of silence before auto-advance

    // Reverb send level per partner
    reverbMix:     0.35,

    // Partner panning (stereo field)
    // G2 left, G3 right, G4 center-left
    pans: [-0.55, 0.55, -0.25],

    // Humanization
    timingJitter:  0.012,     // ± seconds
    ampJitter:     0.10,      // ± fraction

    // Tempo map: [barNumber, bpm]  — mirrors guitar1.xml
    tempoMap: [
        [1,   110],
        [33,   92],
        [49,  110],
        [89,  126],
        [108,  92],   // rit. approximated as single step
    ],
);

// ── Guitar string physical model ──────────────────────────────────────────────
SynthDef(\gtr, { |out=0, freq=220, amp=0.5, decay=2.0, bright=0.48, pan=0|
    var excite = WhiteNoise.ar(0.9) + PinkNoise.ar(0.1);
    var string = Pluck.ar(
        in:            excite,
        trig:          Impulse.ar(0),
        maxdelaytime:  0.05,
        delaytime:     freq.reciprocal,
        decaytime:     decay * (1 - ((freq - 82) / 1200).clip(0, 0.55)),
        coef:          bright
    );
    // Body resonance: low woody body + upper-mid presence
    var body = BPF.ar(string, 280,  0.6) * 0.25
             + BPF.ar(string, 700,  0.9) * 0.20
             + BPF.ar(string, 2200, 1.2) * 0.10;
    var sig  = (string * 0.7 + body * 0.3) * amp;
    DetectSilence.ar(sig, amp: 0.0001, time: 0.3, doneAction: Done.freeSelf);
    Out.ar(out, Pan2.ar(sig, pan));
}).add;

// ── Reverb (GVerb — built-in) ─────────────────────────────────────────────────
SynthDef(\qtrReverb, { |in=4, out=0|
    var sig = In.ar(in, 2);
    var mono = sig.sum * 0.5;
    var wet  = GVerb.ar(mono, roomsize: 28, revtime: 2.8, damping: 0.4,
                         inputbw: 0.75, spread: 15, drylevel: 0, earlyreflevel: 0.5,
                         taillevel: 0.5);
    Out.ar(out, wet * 0.28);
}).add;

// ── Click (sine blip, two pitches: downbeat / subdivision) ────────────────────
SynthDef(\click, { |out=0, freq=880, amp=0.6|
    var sig = SinOsc.ar(freq) * Env.perc(0.001, 0.04).kr(Done.freeSelf) * amp;
    Out.ar(out, sig ! 2);
}).add;

"SynthDefs loaded. Boot server then run Block 2.".postln;
)


// ─────────────────────────────────────────────────────────────────────────────
// BLOCK 2 — SCORE DATA & PLAYBACK
// ─────────────────────────────────────────────────────────────────────────────
(
// Score event format per partner:
//   [barNumber, beatWithinBar, midiNote, durationBeats, amp]
//   beatWithinBar: 1-indexed, fractional OK (1.5 = beat 1 + half beat)
//   durationBeats: in quarter notes
//   amp: 0–1
//
// Counterpoint principles applied:
//   G2 — fills G1 rests, contrary motion tendency, mid register (55–80)
//   G3 — inner voice, often contrary to G2, some ostinato, range (50–72)
//   G4 — bass, slow values, pedal tones, range (40–60)
//
// Section A bars 1–16: G1 plays main theme, partners enter staggered
// Section B bars 17–32: all active, more rhythmic independence
// Section C bars 33–48: sparse, slow — partners thin out
// Section D bars 49–64: partners rebuild with recapitulation
// Section E bars 65–88: crescendo build
// Coda bars 89–110: maximum density then thinning to E unison

// ────────────────────────── GUITAR 2 (countermelody) ─────────────────────────
~g2score = [
//  [bar, beat, midi, dur, amp]
    // Section A — enters at bar 3, fills G1's held/rested spaces
    [3,  1, 71, 2.0, 0.70],  // B4 h  (G1 has F4 h — third below, contrary)
    [3,  3, 69, 2.0, 0.65],  // A4 h
    [5,  1, 74, 1.0, 0.72],  // D5 q
