    [7,  3, 74, 2.0, 0.72],  // D5 h
    [8,  1, 72, 4.0, 0.60],  // C5 w  — long note, G1 rests
    [9,  1, 70, 2.0, 0.70],  // Bb4 h
    [9,  3, 69, 2.0, 0.68],  // A4 h
    [10, 1, 75, 1.0, 0.75],  // Eb5 e-like (1 beat)
    [10, 2, 74, 1.0, 0.72],  // D5
    [10, 3, 72, 2.0, 0.70],  // C5 h
    [11, 1, 68, 1.0, 0.68],  // Ab4 q
    [11, 2, 66, 1.0, 0.65],  // F#4 q
    [11, 3, 67, 2.0, 0.70],  // G4 h
    [12, 1, 64, 4.0, 0.80],  // E4 w — unison octave with G1 E5 (impact moment)
    [13, 2, 72, 1.0, 0.65],  // C5 (G1 rests beat 1)
    [13, 3, 70, 1.0, 0.63],  // Bb4
    [13, 4, 69, 1.0, 0.62],  // A4
